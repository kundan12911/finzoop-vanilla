    "pageIdentifier": {
      "type": "string",
      "unique": true
    },
    "metaTitle": {
      "type": "string"
    },
    "metaDescription": {
      "type": "string"
    },
    "metaKeywords": {
      "type": "string"
    },
    "canonicalUrl": {
      "type": "string"
    },
    "ogTitle": {
      "type": "string"
    },
    "ogDescription": {
      "type": "string"
    },
    "ogImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "twitterTitle": {
      "type": "string"
    },
    "twitterDescription": {
      "type": "string"
    },
    "twitterImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "robotsIndex": {
      "type": "boolean",
      "default": true
    },
    "robotsFollow": {
      "type": "boolean",
      "default": true
    },
    "structuredDataJson": {
      "type": "text"
    },
    "isPublished": {
      "type": "boolean",
      "default": true
    }
